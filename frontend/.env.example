# =============================================================================
# Subscription Billing System - Frontend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================
# All React environment variables MUST be prefixed with REACT_APP_
# https://create-react-app.dev/docs/adding-custom-environment-variables/

# The base URL of the backend API server
# In development: http://localhost:5000
# In production:  https://your-api.onrender.com
REACT_APP_API_URL=http://localhost:5000
