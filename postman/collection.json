        {
          "name": "Create Subscription",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": 1,\n  \"plan_id\": 2,\n  \"start_date\": \"2026-06-01\",\n  \"billing_cycle\": \"monthly\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/subscriptions",
              "host": ["{{baseUrl}}"],
              "path": ["subscriptions"]
            }
          }
        },
        {
          "name": "Upgrade Subscription",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"new_plan_id\": 3\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/subscriptions/1/upgrade",
              "host": ["{{baseUrl}}"],
              "path": ["subscriptions", "1", "upgrade"]
            }
          }
        },
        {
          "name": "Downgrade Subscription",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"new_plan_id\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/subscriptions/1/downgrade",
              "host": ["{{baseUrl}}"],
              "path": ["subscriptions", "1", "downgrade"]
            }
          }
        },
        {
