            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/subscriptions/1/renew",
              "host": ["{{baseUrl}}"],
              "path": ["subscriptions", "1", "renew"]
            }
          }
        }
      ]
    },
